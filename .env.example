# Copy to .env and fill in the values you need. .env is gitignored.
# Pydantic-settings loads this via env_prefix="OHSHEET_" from the repo root.

# --- Refine stage (LLM-driven score metadata) ---
# Anthropic API key — required when OHSHEET_REFINE_ENABLED=true (the default).
# Without it, the refine stage falls back to pass-through on every job.
OHSHEET_ANTHROPIC_API_KEY=

# Optional overrides — leave commented to use the defaults in backend/config.py.
# OHSHEET_REFINE_ENABLED=true
# OHSHEET_REFINE_MODEL=claude-sonnet-4-6
# OHSHEET_REFINE_MAX_SEARCHES=5
# OHSHEET_REFINE_BUDGET_SEC=300
# OHSHEET_REFINE_CALL_TIMEOUT_SEC=120

# --- TuneChat integration (ingest → transcribe via external service) ---
# OHSHEET_TUNECHAT_ENABLED=false
# OHSHEET_TUNECHAT_URL=https://tunechat.fly.dev
# OHSHEET_TUNECHAT_API_KEY=
# httpx client timeout (seconds) for the orchestrator → TuneChat POST.
# Default 300 is fine for short tracks; raise to 900 for long-track
# transcription (10-min audio takes 6-10 min on TuneChat). Deploy sets
# this via the env-scoped GitHub variable of the same name.
# OHSHEET_TUNECHAT_TIMEOUT_SEC=300

# --- Engrave stage ---
# Backend selection: "local" (music21 → MusicXML + LilyPond → PDF, in-process)
# or "remote_http" (POST MIDI to the oh-sheet-ml-pipeline service). Local is
# the default and falls through to remote_http on EngraveLocalError (e.g.
# missing LilyPond install). See README "Engraver service" section.
# OHSHEET_ENGRAVE_BACKEND=local

# URL of the oh-sheet-ml-pipeline HTTP engraver. Used when the backend is
# remote_http or when the local backend falls through. The service is a
# proprietary Oh Sheet component — see github.com/Oh-Sheet-Team/oh-sheet/issues/107
# for the open-sourcing discussion. Self-hosters can run on the local
# backend and leave this unset.
# OHSHEET_ENGRAVER_SERVICE_URL=http://localhost:8080
# OHSHEET_ENGRAVER_SERVICE_TIMEOUT_SEC=60

# --- Core infra ---
# OHSHEET_REDIS_URL=redis://localhost:6379/0
# OHSHEET_BLOB_ROOT=./blob
# OHSHEET_LOG_LEVEL=INFO
